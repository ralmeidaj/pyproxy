{
    "openapi": "3.0.0",
    "info": {
        "title": "Payproxy API",
        "description": "API pública para emissão de boletos bancários com split de pagamento. Autenticação via API Key no header `X-Api-Key`.",
        "contact": {
            "name": "Ciberian",
            "email": "suporte@ciberian.com.br"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1",
            "description": "Produção"
        }
    ],
    "paths": {
        "/boletos/batch": {
            "post": {
                "tags": [
                    "Boletos"
                ],
                "summary": "Emitir lote de boletos",
                "description": "Cria um lote de até 500 boletos. O processamento é assíncrono: retorna HTTP 202 com o ID do lote para consulta posterior. A operação é idempotente por `external_ref` por tenant.",
                "operationId": "9bb1004f9d2cae05c79da89d1f13be89",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "external_ref",
                                    "boletos"
                                ],
                                "properties": {
                                    "external_ref": {
                                        "description": "Referência única do lote por tenant",
                                        "type": "string",
                                        "example": "LOTE-IPTU-2026-07"
                                    },
                                    "boletos": {
                                        "type": "array",
                                        "items": {
                                            "type": "object"
                                        },
                                        "maxItems": 500
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "202": {
                        "description": "Lote aceito para processamento"
                    },
                    "401": {
                        "description": "API Key inválida ou ausente"
                    },
                    "409": {
                        "description": "external_ref já existe para este tenant"
                    },
                    "422": {
                        "description": "Dados inválidos"
                    }
                },
                "security": [
                    {
                        "ApiKey": []
                    }
                ]
            }
        },
        "/boletos/batch/{batch_id}": {
            "get": {
                "tags": [
                    "Boletos"
                ],
                "summary": "Consultar status do lote",
                "description": "Retorna o status de processamento do lote e os resultados individuais de cada boleto.",
                "operationId": "0dfe1850823df86e708a841b519004fa",
                "parameters": [
                    {
                        "name": "batch_id",
                        "in": "path",
                        "description": "ID do lote",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Status do lote"
                    },
                    "404": {
                        "description": "Lote não encontrado"
                    }
                },
                "security": [
                    {
                        "ApiKey": []
                    }
                ]
            }
        },
        "/boletos": {
            "post": {
                "tags": [
                    "Boletos"
                ],
                "summary": "Emitir boleto",
                "description": "Emite um boleto registrado com split de pagamento automático conforme a configuração do tenant. A operação é idempotente: requisições com o mesmo `pedido_numero` retornam o boleto existente.",
                "operationId": "39a41f6cc97183acbd1e03e236b54883",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "pedido_numero",
                                    "valor",
                                    "vencimento",
                                    "nome_cliente",
                                    "cpf_cliente",
                                    "endereco_cliente",
                                    "numero_cliente",
                                    "bairro_cliente",
                                    "cidade_cliente",
                                    "estado_cliente",
                                    "cep_cliente"
                                ],
                                "properties": {
                                    "pedido_numero": {
                                        "description": "Referência externa única do tenant",
                                        "type": "string",
                                        "example": "NF-2024-001"
                                    },
                                    "valor": {
                                        "description": "Valor do boleto em reais (string com 2 casas decimais)",
                                        "type": "string",
                                        "example": "150.00"
                                    },
                                    "vencimento": {
                                        "description": "Data de vencimento no formato MM/DD/YYYY",
                                        "type": "string",
                                        "example": "07/30/2026"
                                    },
                                    "nome_cliente": {
                                        "description": "Nome completo do pagador",
                                        "type": "string",
                                        "example": "João da Silva"
                                    },
                                    "cpf_cliente": {
                                        "description": "CPF ou CNPJ do pagador (formatado ou somente dígitos)",
                                        "type": "string",
                                        "example": "123.456.789-09"
                                    },
                                    "email_cliente": {
                                        "description": "E-mail do pagador (opcional)",
                                        "type": "string",
                                        "example": "joao@example.com"
                                    },
                                    "telefone_cliente": {
                                        "description": "Telefone do pagador (opcional)",
                                        "type": "string",
                                        "example": "71999990000"
                                    },
                                    "endereco_cliente": {
                                        "description": "Logradouro do pagador",
                                        "type": "string",
                                        "example": "Rua das Flores"
                                    },
                                    "numero_cliente": {
                                        "description": "Número do endereço",
                                        "type": "string",
                                        "example": "42"
                                    },
                                    "complemento_cliente": {
                                        "description": "Complemento (opcional)",
                                        "type": "string",
                                        "example": "Apto 3"
                                    },
                                    "bairro_cliente": {
                                        "description": "Bairro do pagador",
                                        "type": "string",
                                        "example": "Centro"
                                    },
                                    "cidade_cliente": {
                                        "description": "Cidade do pagador",
                                        "type": "string",
                                        "example": "Salvador"
                                    },
                                    "estado_cliente": {
                                        "description": "UF do pagador (2 letras)",
                                        "type": "string",
                                        "example": "BA"
                                    },
                                    "cep_cliente": {
                                        "description": "CEP do pagador",
                                        "type": "string",
                                        "example": "40000-000"
                                    },
                                    "metadata": {
                                        "description": "Dados adicionais livres (opcional)",
                                        "type": "object",
                                        "example": {
                                            "tipo": "IPTU"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Boleto emitido com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BoletoResource"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "API Key inválida ou ausente"
                    },
                    "403": {
                        "description": "Tenant inativo ou escopo insuficiente"
                    },
                    "422": {
                        "description": "Dados inválidos"
                    },
                    "429": {
                        "description": "Rate limit atingido"
                    },
                    "502": {
                        "description": "Falha na comunicação com o parceiro bancário"
                    }
                },
                "security": [
                    {
                        "ApiKey": []
                    }
                ]
            }
        },
        "/boletos/{nossonumero}": {
            "get": {
                "tags": [
                    "Boletos"
                ],
                "summary": "Consultar boleto",
                "description": "Retorna os dados de um boleto pelo seu ID interno (nossonumero).",
                "operationId": "0d076a7eae0927c2e89f44937c287899",
                "parameters": [
                    {
                        "name": "nossonumero",
                        "in": "path",
                        "description": "ID interno do boleto",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Dados do boleto",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BoletoResource"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "API Key inválida ou ausente"
                    },
                    "404": {
                        "description": "Boleto não encontrado ou pertence a outro tenant"
                    }
                },
                "security": [
                    {
                        "ApiKey": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Boletos"
                ],
                "summary": "Cancelar boleto",
                "description": "Cancela um boleto pendente. Boletos pagos ou já cancelados não podem ser cancelados (RN-03).",
                "operationId": "46c1b59203528e902f62bddb285a4e30",
                "parameters": [
                    {
                        "name": "nossonumero",
                        "in": "path",
                        "description": "ID interno do boleto",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Boleto cancelado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Boleto cancelado com sucesso."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "API Key inválida ou ausente"
                    },
                    "404": {
                        "description": "Boleto não encontrado ou pertence a outro tenant"
                    },
                    "422": {
                        "description": "Boleto não pode ser cancelado (status atual não permite)"
                    }
                },
                "security": [
                    {
                        "ApiKey": []
                    }
                ]
            }
        },
        "/webhooks/pjbank": {
            "post": {
                "tags": [
                    "Webhooks"
                ],
                "summary": "Webhook de pagamento PJBank",
                "description": "Endpoint chamado pelo PJBank para notificar pagamentos. Não é chamado pelos tenants. A autenticidade é validada via HMAC-SHA256 (header `X-PJBank-Hmac-Sha256`) e pela credencial do boleto. Retorna 200 mesmo em cenários de idempotência para evitar retentativas do PJBank.",
                "operationId": "697cc741e2e222b9c02f4e5107656ecd",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "nosso_numero": {
                                        "description": "Identificador do boleto no PJBank",
                                        "type": "string",
                                        "example": "99999999"
                                    },
                                    "token_transaction": {
                                        "description": "Token alternativo de identificação",
                                        "type": "string",
                                        "example": "tok_abc123"
                                    },
                                    "credencial": {
                                        "description": "Credencial do tenant no PJBank (validada fail-closed)",
                                        "type": "string",
                                        "example": "cred_xxxxx"
                                    },
                                    "valor": {
                                        "description": "Valor pago em reais",
                                        "type": "number",
                                        "example": 150
                                    },
                                    "forma_pagamento": {
                                        "description": "Canal de pagamento: barcode, pix, ted, etc.",
                                        "type": "string",
                                        "example": "pix"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Notificação processada (ou ignorada por idempotência)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "ok": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Assinatura HMAC inválida ou credencial incorreta/ausente"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "BoletoResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 42
                    },
                    "nossonumero": {
                        "type": "string",
                        "example": "559353941"
                    },
                    "pedido_numero": {
                        "type": "string",
                        "example": "NF-2024-001"
                    },
                    "valor": {
                        "type": "string",
                        "example": "150.00"
                    },
                    "vencimento": {
                        "type": "string",
                        "example": "07/30/2026"
                    },
                    "nome_cliente": {
                        "type": "string",
                        "example": "João da Silva"
                    },
                    "cpf_cliente": {
                        "type": "string",
                        "example": "12345678909"
                    },
                    "email_cliente": {
                        "type": "string",
                        "example": "joao@example.com"
                    },
                    "linhaDigitavel": {
                        "type": "string",
                        "example": "48190.00003 00005.15055 ..."
                    },
                    "linkBoleto": {
                        "type": "string",
                        "example": "https://api.pjbank.com.br/boletos/abc123"
                    },
                    "linkpix": {
                        "type": "string",
                        "example": null,
                        "nullable": true
                    },
                    "dda_registered": {
                        "type": "boolean",
                        "example": true
                    },
                    "status": {
                        "type": "string",
                        "example": "pending",
                        "enum": [
                            "pending",
                            "paid",
                            "cancelled",
                            "expired"
                        ]
                    },
                    "status_label": {
                        "type": "string",
                        "example": "Pendente"
                    },
                    "paid_at": {
                        "type": "string",
                        "example": null,
                        "nullable": true
                    },
                    "cancelled_at": {
                        "type": "string",
                        "example": null,
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "example": "2026-07-01T12:00:00-03:00"
                    },
                    "split": {
                        "type": "array",
                        "items": {
                            "properties": {
                                "nome": {
                                    "type": "string",
                                    "example": "ORBY TECNOLOGIA"
                                },
                                "valor_fixo": {
                                    "type": "string",
                                    "example": "11.20"
                                },
                                "porcentagem_encargos": {
                                    "type": "number",
                                    "example": 0
                                }
                            },
                            "type": "object"
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "ApiKey": {
                "type": "apiKey",
                "description": "API Key gerada no backoffice Payproxy. Formato: `ppx_<40 chars>`.",
                "name": "X-Api-Key",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Boletos",
            "description": "Emissão, consulta e cancelamento de boletos"
        },
        {
            "name": "Webhooks",
            "description": "Webhooks"
        }
    ]
}